# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App URL (used for OAuth callback redirects)
NEXT_PUBLIC_APP_URL=https://upscprelimstest.com

# Gemini (required for PYQ import)
GEMINI_API_KEY=
# Optional: choose a model available in your region/account
GEMINI_MODEL=gemini-3-flash-preview

# Cloud Vision OCR (required for PNG/JPG ingestion)
GOOGLE_VISION_API_KEY=

# Document AI OCR (required for PDF ingestion)
# Document AI uses service account / ADC (not an API key).
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us
DOCUMENTAI_PROCESSOR_ID=
